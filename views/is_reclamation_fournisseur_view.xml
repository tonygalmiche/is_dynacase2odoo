<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>


        <!-- Tree view -->
        <record id="is_reclamation_fournisseur_tree" model="ir.ui.view">
            <field name="name">is.reclamation.fournisseur.tree</field>
            <field name="model">is.reclamation.fournisseur</field>
            <field name="arch" type="xml">
                <tree string="Réclamations fournisseurs" create="1" delete="0">
                    <!-- Identification -->
                    <field name="site_id" optional="show"/>
                    <field name="num_reclamation" optional="show"/>
                    <field name="nature_reclamation" optional="show"/>
                    <field name="decision" optional="show" widget="badge"
                        decoration-success="decision == 'cloture'"
                        decoration-muted="decision == 'annule'"
                        decoration-warning="decision == 'escalade_achats'"/>
                    <field name="date_detection_defaut" optional="show"/>
                    <field name="annee_detection_defaut" optional="hide"/>
                    <field name="date_creation" optional="show"/>


                    <!-- Réception concernée -->
                    <field name="num_reception" optional="show"/>
                    <field name="nom_fournisseur" optional="show"/>
                    <field name="adr_fournisseur" optional="hide"/>
                    <field name="code_fournisseur" optional="hide"/>
                    <field name="codepg" optional="hide"/>
                    <field name="designation" optional="hide"/>
                    <field name="ref_fournisseur" optional="hide"/>
                    <field name="num_bl_fournisseur" optional="hide"/>
                    <field name="num_commande" optional="hide"/>
                    <field name="prix_achat_commande" optional="hide"/>
                    <field name="quantite_livree" optional="hide"/>
                    <field name="date_reception" optional="hide"/>


                    <!-- Description -->
                    <field name="quantite_nc" optional="hide"/>
                    <field name="quantite_a_facturer" optional="hide"/>
                    <field name="defaut_constate_choix" optional="hide"/>
                    <field name="reclamation_recurrente" optional="hide"/>
                    <field name="suppression_aqp" optional="hide"/>
                    <field name="commentaire_description" optional="hide"/>

                    <!-- Tri interne Plastigray -->
                    <field name="motif_tri" optional="hide"/>
                    <field name="nombre_heures" optional="hide"/>

                    <!-- Photo -->
                    <field name="photo" optional="hide"/>

                    <!-- Réponse fournisseur (réel) -->
                    <field name="date_secu_fourn_reel" optional="hide"/>
                    <field name="date_analyse_reel" optional="hide"/>
                    <field name="date_plan_reel" optional="hide"/>
                    <field name="date_cloture_reel" optional="hide"/>

                    <!-- Réponse fournisseur (objectif) -->
                    <field name="date_secu_fourn_obj" optional="hide"/>
                    <field name="date_analyse_obj" optional="hide"/>
                    <field name="date_plan_obj" optional="hide"/>
                    <field name="date_cloture_obj" optional="hide"/>

                    <!-- Commentaire réponse -->
                    <field name="commentaire_reponse" optional="hide"/>

                    <!-- Coûts globaux -->
                    <field name="couts_produits"  optional="hide"/>
                    <field name="couts_tris"      optional="hide"/>
                    <field name="autres_couts"    optional="hide"/>
                    <field name="somme_des_couts" optional="hide"/>
                    <field name="couts_compta"    optional="hide"/>
                    <field name="ecart_cout"      optional="hide"/>

                    <!-- Champs d'audit -->
                    <field name="create_date" optional="hide" string="Créé le"/>
                    <field name="create_uid"  optional="hide" string="Créé par"/>
                    <field name="write_date"  optional="hide" string="Modifié le"/>
                    <field name="write_uid"   optional="hide" string="Modifié par"/>
                </tree>
            </field>
        </record>

        <!-- Search view -->
        <record id="is_reclamation_fournisseur_search" model="ir.ui.view">
            <field name="name">is.reclamation.fournisseur.search</field>
            <field name="model">is.reclamation.fournisseur</field>
            <field name="arch" type="xml">
                <search string="Recherche Réclamation">
                    <field name="site_id"/>
                    <field name="num_reclamation"/>
                    <field name="num_reception"/>
                    <field name="nature_reclamation"/>
                    <field name="nom_fournisseur"/>
                    <field name="codepg"/>
                    <field name="annee_detection_defaut"/>
                    <field name="decision"/>
                    <group expand="0" string="Group By">
                        <filter name="group_fournisseur" string="Fournisseur" context="{'group_by': 'nom_fournisseur'}"/>
                        <filter name="group_annee" string="Année détection" context="{'group_by': 'annee_detection_defaut'}"/>
                        <filter name="group_date_creation" string="Date création" context="{'group_by': 'date_creation'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Form view -->
        <record id="is_reclamation_fournisseur_form" model="ir.ui.view">
            <field name="name">is.reclamation.fournisseur.form</field>
            <field name="model">is.reclamation.fournisseur</field>
            <field name="arch" type="xml">
                <form string="Réclamation fournisseur">
                    <sheet>
                        <field name="active" invisible="1"/>
                        <field name="annee_detection_defaut" invisible="1"/>
                        <widget name="web_ribbon" title="Archivé" bg_color="bg-danger" attrs="{'invisible': [('active', '=', True)]}"/>

                        <notebook>
                            <page string="Réclamation fournisseur">
                                <div class="row">
                                    <!-- Colonne gauche -->
                                    <div class="col-6">
                                        <group string="Information sur la non-conformité">
                                            <field name="num_reclamation"/>
                                            <field name="nature_reclamation" required="1"/>
                                            <field name="site_id" required="1"/>
                                            <field name="create_uid" string="Créateur"/>
                                            <field name="date_detection_defaut" required="1"/>
                                            <field name="date_creation"/>
                                            <field name="reclamation_recurrente"/>
                                        </group>

                                        <group string="Réception concernée par la non-conformité">
                                            <field name="reception_id"/>
                                            <field name="num_reception" force_save="1" invisible="1"/>
                                            <field name="fournisseur_id"/>
                                            <field name="nom_fournisseur" force_save="1" readonly="1"/>
                                            <field name="adr_fournisseur" force_save="1" readonly="1"/>
                                            <field name="code_fournisseur" force_save="1" readonly="1"/>
                                            <field name="codepg" force_save="1" readonly="1"/>
                                            <field name="designation" force_save="1" readonly="1"/>
                                            <field name="ref_fournisseur" force_save="1" readonly="1"/>
                                            <field name="num_bl_fournisseur" force_save="1" readonly="1"/>
                                            <field name="num_commande" force_save="1" readonly="1"/>
                                            <field name="prix_achat_commande" force_save="1" readonly="1"/>
                                            <field name="quantite_livree" force_save="1" readonly="1"/>
                                            <field name="date_reception" force_save="1" readonly="1"/>
                                        </group>

                                        <group string="Synthèse des coûts">
                                            <field name="cout_ctrl_qualite_vendu_fournisseur"/>
                                            <field name="couts_tris"/>
                                            <field name="forfait_qualite" readonly="1"/>
                                            <separator colspan="2"/>
                                            <field name="couts_produits"/>
                                            <field name="autres_couts"/>
                                            <separator colspan="2"/>
                                            <field name="somme_des_couts"/>
                                        </group>

                                        <group string="Suivi des facturations" style="overflow:hidden">
                                            <!-- overflow:hidden : nécessaire pour l'alignement de la grille du formulaire,
                                                 sinon le tableau (trop large à cause de la colonne bouton ci-dessous)
                                                 déborde et décale les champs voisins.
                                                 delete="false" + bouton unlink manuel : la poubelle native d'Odoo est
                                                 clippée par le layout 2 colonnes du formulaire (col-6). Le bouton manuel
                                                 prend une colonne trop large (Odoo classe un <button> isolé en colonne
                                                 "relative", il n'y a pas moyen de la forcer plus étroite sans casser
                                                 l'affichage de la poubelle) mais au moins elle est visible et utilisable. -->
                                            <field name="cout_compta_ids" context="{'default_reclamation_id': active_id}" nolabel="1" colspan="2">
                                                <tree editable="bottom" delete="false">
                                                    <field name="site_id" column_invisible="1"/>
                                                    <field name="facture_id"/>
                                                    <field name="num_facture"/>
                                                    <field name="date_cout"/>
                                                    <field name="montant"/>
                                                    <button name="unlink" type="object" icon="fa-trash-o" string="" confirm="Voulez-vous supprimer cette ligne ?"/>
                                                </tree>
                                            </field>
                                            <field name="couts_compta"/>
                                            <field name="ecart_cout"/>
                                            <field name="commentaire_interne_facturation"/>
                                        </group>
                                    </div>

                                    <!-- Colonne droite -->
                                    <div class="col-6">
                                        <group string="Description de la non-conformité">
                                            <field name="defaut_constate_choix" string="Défaut constaté"/>
                                            <field name="commentaire_description"/>
                                            <field name="quantite_nc" string="Quantité concernée"/>
                                        </group>

                                        <div style="text-align:center">
                                            <field name="photo" widget="image" style="max-width:600px"/>
                                        </div>

                                        <group string="Sécurisation">
                                            <field name="motif_tri"/>
                                            <field name="nombre_heures"/>
                                        </group>

                                        <group string="Analyse de la réponse fournisseur">
                                            <field name="reponse_fournisseur"/>
                                            <field name="commentaire_reponse"/>
                                        </group>

                                        <group string="Conclusion sur la non-conformité" style="overflow:hidden">
                                            <field name="quantite_a_facturer"/>
                                            <field name="forfait_qualite"/>
                                            <!-- overflow:hidden + delete="false" + bouton unlink manuel : voir commentaire
                                                 sur cout_compta_ids ci-dessus (même bug d'affichage, même contournement). -->
                                            <field name="autre_cout_ids" string="Coûts supplémentaires" context="{'default_reclamation_id': active_id}" nolabel="1" colspan="2">
                                                <tree editable="bottom" delete="false">
                                                    <field name="type_cout" string="Coûts supplémentaires"/>
                                                    <field name="montant_autre" string="Montant"/>
                                                    <button name="unlink" type="object" icon="fa-trash-o" string="" confirm="Voulez-vous supprimer cette ligne ?"/>
                                                </tree>
                                            </field>
                                            <field name="suppression_aqp"/>
                                            <field name="decision"/>
                                            <field name="date_cloture_reel"/>
                                            <field name="explication_decision"/>
                                        </group>

                                        <group string="Pièce jointe">
                                            <field name="piece_jointe_ids" widget="many2many_binary" nolabel="1" colspan="2"/>
                                        </group>
                                    </div>
                                </div>
                            </page>

                            <page string="Autre">
                                <!-- <group string="Nature de la réclamation">
                                    <field name="type_reclamation"/>
                                    <field name="nature_qualite"/>
                                    <field name="nature_logistique"/>
                                    <field name="nature_administratif"/>
                                </group> 
                                -->
                                <group>
                                    <group string="Réponse fournisseur (objectif)">
                                        <field name="date_secu_fourn_obj"/>
                                        <field name="date_analyse_obj"/>
                                        <field name="date_plan_obj"/>
                                        <field name="date_cloture_obj"/>
                                    </group>
                                    <group string="Réponse fournisseur (réel)">
                                        <field name="date_secu_fourn_reel"/>
                                        <field name="date_analyse_reel"/>
                                        <field name="date_plan_reel"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>


        <!-- Graph view -->
        <record id="is_reclamation_fournisseur_graph_view" model="ir.ui.view">
            <field name="name">is_reclamation_fournisseur_graph_view</field>
            <field name="model">is.reclamation.fournisseur</field>
            <field name="arch" type="xml">
                <graph string="Réclamations fournisseurs" type="bar">
                    <field name="nom_fournisseur" type="row"/>
                </graph>
            </field>
        </record>

        <!-- Pivot view -->
        <record id="is_reclamation_fournisseur_pivot_view" model="ir.ui.view">
            <field name="name">is_reclamation_fournisseur_pivot_view</field>
            <field name="model">is.reclamation.fournisseur</field>
            <field name="arch" type="xml">
                <pivot string="Réclamations fournisseurs">
                    <field name="nature_reclamation" type="col"/>
                    <field name="nom_fournisseur" type="row"/>
                </pivot>
            </field>
        </record>

        <!-- Action -->
        <record id="is_reclamation_fournisseur_action" model="ir.actions.act_window">
            <field name="name">Réclamations fournisseurs</field>
            <field name="res_model">is.reclamation.fournisseur</field>
            <field name="view_mode">tree,form,graph,pivot</field>
            <field name="context">{}</field>
            <field name="domain">[]</field>
            <field name="help" type="html">
                <p>Créer et suivre les réclamations fournisseurs.</p>
            </field>
        </record>

        <!-- Action serveur pour recalculer les coûts -->
        <record id="is_reclamation_fournisseur_action_recalculer_couts" model="ir.actions.server">
            <field name="name">Recalculer les coûts</field>
            <field name="model_id" ref="model_is_reclamation_fournisseur"/>
            <field name="binding_model_id" ref="model_is_reclamation_fournisseur"/>
            <field name="binding_view_types">list,form</field>
            <field name="state">code</field>
            <field name="code">
if records:
    action = records.action_recalculer_couts()
            </field>
        </record>


        <!-- Action serveur pour recalculer les coûts -->
        <record id="maj_quantite_livree_action_serveur" model="ir.actions.server">
            <field name="name">Mise à jour quantité livrée</field>
            <field name="model_id" ref="model_is_reclamation_fournisseur"/>
            <field name="binding_model_id" ref="model_is_reclamation_fournisseur"/>
            <field name="binding_view_types">list,form</field>
            <field name="state">code</field>
            <field name="code">
if records:
    action = records.maj_quantite_livree_action()
            </field>
        </record>
    </data>
</odoo>
