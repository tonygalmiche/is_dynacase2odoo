<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="is_prompt_ia_tree_view" model="ir.ui.view">
        <field name="name">is.prompt.ia.tree</field>
        <field name="model">is.prompt.ia</field>
        <field name="arch" type="xml">
            <tree>
                <field name="modele_id" optional="show"/>
                <field name="field_id" optional="show"/>
                <field name="famille_ids" widget="many2many_tags" optional="show"/>
                <field name="prompt" optional="show"/>
                <field name="prompt_actif" optional="show" widget="boolean_toggle"/>
                <field name="detail_analyse_ia" optional="show" widget="boolean_toggle"/>
                <field name="reflexion" optional="show" widget="boolean_toggle"/>
                <field name="create_date" optional="hide" string="Créé le"/>
                <field name="create_uid" optional="hide" string="Créé par"/>
                <field name="write_date" optional="hide" string="Modifié le"/>
                <field name="write_uid" optional="hide" string="Modifié par"/>
            </tree>
        </field>
    </record>

    <record id="is_prompt_ia_form_view" model="ir.ui.view">
        <field name="name">is.prompt.ia.form</field>
        <field name="model">is.prompt.ia</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archivé" bg_color="bg-danger" attrs="{'invisible': [('active', '=', True)]}"/>
                    <group>
                        <group>
                            <field name="modele_id"/>
                            <field name="field_id" domain="[('model_id', '=', modele_id), ('ttype', 'not in', ['many2many', 'one2many', 'reference', 'binary', 'serialized']), ('store', '=', True)]"/>
                            <field name="famille_ids" widget="many2many_tags" domain="[('type_document', '=', 'Article')]"/>
                        </group>
                        <group>
                            <field name="prompt_actif" widget="boolean_toggle"/>
                            <field name="detail_analyse_ia" widget="boolean_toggle"/>
                            <field name="reflexion" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <group string="Prompt">
                        <field name="prompt" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="is_prompt_ia_search_view" model="ir.ui.view">
        <field name="name">is.prompt.ia.search</field>
        <field name="model">is.prompt.ia</field>
        <field name="arch" type="xml">
            <search>
                <field name="modele_id"/>
                <field name="field_id"/>
                <filter string="Archivé" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Regrouper par">
                    <filter string="Modèle" name="group_modele" context="{'group_by': 'modele_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="is_prompt_ia_action" model="ir.actions.act_window">
        <field name="name">Prompts IA</field>
        <field name="res_model">is.prompt.ia</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="is_prompt_ia_menu"
              name="Prompts IA"
              parent="is_vllm2odoo.is_vllm_menu_root"
              action="is_prompt_ia_action"
              groups="is_vllm2odoo.group_ia_gestionnaire_prompts"
              sequence="20"/>

</odoo>
